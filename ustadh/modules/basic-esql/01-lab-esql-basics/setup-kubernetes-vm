#!/bin/bash
# Instruqt lifecycle script for ESA (Elastic Security Analytics) tracks
# Restores the esa-8-18-v3 snapshot (pre-baked with 8.x mapping fixes and
# pre-migrated .siem-signals → .internal.alerts), sets time picker defaults
# to the BLISTER data range (Feb-Mar 2022).

export $(curl -s http://kubernetes-vm:9000/env | xargs)

# /opt/workshops/elastic-view.sh -v security

# /opt/workshops/elastic-llm.sh -m gpt-4o -k true
# /opt/workshops/elastic-llm.sh -m cohere -k true

# # load ELSER, but don't start it
# /opt/workshops/elastic-semantic.sh -e true -s false

# Provision LLM connector using anthropic model and setup knowledgebase
# /opt/workshops/elastic-llm.sh -m anthropic

# ── Restore snapshot ──
# Snapshot contains data indices + pre-migrated alerts in
# .internal.alerts-security.alerts-default-000001 (signal.* → kibana.alert.*
# with subtechnique normalization). Kibana creates an empty alerts index on
# boot, so we delete it first to avoid restore conflict.
curl -s -X DELETE "${ELASTICSEARCH_URL}/.internal.alerts-security.alerts-default-000001" \
  -H "Authorization: Basic ${ELASTICSEARCH_AUTH_BASE64}"

/opt/workshops/elastic-snapshot.sh \
  -p teams/swimlane-security/esa-8-18-v3 \
  -b ce-infra-dev-elasticsearch-snapshots \
  -c education \
  -n esa \
  -s esa-8-18-v3 \
  -g false

# ── Install prebuilt detection rules + custom rules ──
# The migrated alerts reference rules (by rule_id) that don't exist on a fresh
# cluster. Install prebuilt rules first, then create the custom rules that were
# on the original 7.x cluster so alert click-throughs work.
curl -s -X PUT "http://kubernetes-vm:30001/api/detection_engine/rules/prepackaged" \
  -H "kbn-xsrf: true" \
  -H "Authorization: Basic ${ELASTICSEARCH_AUTH_BASE64}"

# Create custom rules that aren't in the prebuilt package.
# These are disabled (enabled: false) — they exist only so clicking an alert
# shows the rule detail page instead of crashing.
KIBANA="http://kubernetes-vm:30001"
AUTH="Authorization: Basic ${ELASTICSEARCH_AUTH_BASE64}"

# Possible Cryptominer (custom)
curl -s -X POST "${KIBANA}/api/detection_engine/rules" \
  -H "kbn-xsrf: true" -H "${AUTH}" -H "Content-Type: application/json" \
  -d '{
    "rule_id": "44967357-f9f1-4648-80ea-3df02f0da542",
    "name": "Possible Cryptominer",
    "description": "xmrig is a cryptominer and this rule is designed to alert whenever this string is present in the process.arg",
    "type": "query",
    "query": "process.args : \"xmrig\"",
    "language": "kuery",
    "index": ["apm-*-transaction*","traces-apm*","auditbeat-*","endgame-*","filebeat-*","logs-*","packetbeat-*","winlogbeat-*"],
    "severity": "high",
    "risk_score": 73,
    "from": "now-3900s",
    "to": "now",
    "tags": ["custom","development","testing-30d"],
    "enabled": false
  }' > /dev/null 2>&1

# Malware Detection Alert (endpoint wrapper)
curl -s -X POST "${KIBANA}/api/detection_engine/rules" \
  -H "kbn-xsrf: true" -H "${AUTH}" -H "Content-Type: application/json" \
  -d '{
    "rule_id": "9a1a2dae-0b5f-4c3d-8305-a268d404c306",
    "name": "Malware Detection Alert",
    "description": "Generates a detection alert each time an Elastic Endpoint Security alert is received. Enabling this rule allows you to immediately begin investigating your Endpoint alerts.",
    "type": "query",
    "query": "event.kind:alert and event.module:(endpoint and not endgame)",
    "language": "kuery",
    "index": ["logs-endpoint.alerts-*"],
    "severity": "critical",
    "risk_score": 99,
    "from": "now-10m",
    "to": "now",
    "tags": ["Elastic","Endpoint Security"],
    "enabled": false
  }' > /dev/null 2>&1

# Threat Intel Filebeat Module (v7.x) Indicator Match (placeholder — original was threat_match type)
curl -s -X POST "${KIBANA}/api/detection_engine/rules" \
  -H "kbn-xsrf: true" -H "${AUTH}" -H "Content-Type: application/json" \
  -d '{
    "rule_id": "dc672cb7-d5df-4d1f-a6d7-0841b1caafb9",
    "name": "Threat Intel Filebeat Module (v7.x) Indicator Match",
    "description": "This rule is triggered when indicators from the Threat Intel Filebeat module (v7.x) has a match against local file or network observations.",
    "type": "query",
    "query": "file.hash.*:* or source.ip:* or destination.ip:* or url.full:*",
    "language": "kuery",
    "index": ["auditbeat-*","endgame-*","filebeat-*","logs-*","packetbeat-*","winlogbeat-*"],
    "severity": "critical",
    "risk_score": 99,
    "from": "now-65m",
    "to": "now",
    "tags": ["Elastic","Windows","Elastic Endgame","Network","Continuous Monitoring","SecOps","Monitoring"],
    "enabled": false
  }' > /dev/null 2>&1

# Threat Intel Filebeat Module (v7.x) Indicator Match [Duplicate]
curl -s -X POST "${KIBANA}/api/detection_engine/rules" \
  -H "kbn-xsrf: true" -H "${AUTH}" -H "Content-Type: application/json" \
  -d '{
    "rule_id": "c383d939-a0c7-4bea-b603-693e4c56f5fc",
    "name": "Threat Intel Filebeat Module (v7.x) Indicator Match [Duplicate]",
    "description": "This rule is triggered when indicators from the Threat Intel Filebeat module (v7.x) has a match against local file or network observations.",
    "type": "query",
    "query": "file.hash.*:* or source.ip:* or destination.ip:* or url.full:*",
    "language": "kuery",
    "index": ["auditbeat-*","endgame-*","filebeat-*","logs-*","packetbeat-*","winlogbeat-*"],
    "severity": "critical",
    "risk_score": 99,
    "from": "now-360s",
    "to": "now",
    "tags": ["Elastic","Windows","Elastic Endgame","Network","Continuous Monitoring","SecOps","Monitoring"],
    "enabled": false
  }' > /dev/null 2>&1

# ── Set time picker to BLISTER data range ──
curl -s -X PUT "http://kubernetes-vm:30001/api/saved_objects/config/$ELASTICSEARCH_VERSION" \
  -H "Content-Type: application/json" \
  -H "kbn-xsrf: true" \
  -H "Authorization: Basic $ELASTICSEARCH_AUTH_BASE64" \
  -d '{
    "attributes": {
      "timepicker:quickRanges": "[{\"from\":\"2022-02-01T00:00:00.000Z\",\"to\":\"2022-03-31T23:59:59.999Z\",\"display\":\"BLISTER\"},{\"from\":\"now/d\",\"to\":\"now/d\",\"display\":\"Today\"},{\"from\":\"now/w\",\"to\":\"now/w\",\"display\":\"This week\"},{\"from\":\"now-15m\",\"to\":\"now\",\"display\":\"Last 15 minutes\"},{\"from\":\"now-1h\",\"to\":\"now\",\"display\":\"Last 1 hour\"},{\"from\":\"now-7d/d\",\"to\":\"now\",\"display\":\"Last 7 days\"},{\"from\":\"now-30d/d\",\"to\":\"now\",\"display\":\"Last 30 days\"}]",
      "timepicker:timeDefaults": "{\"from\":\"2022-02-01T00:00:00.000Z\",\"to\":\"2022-03-31T23:59:59.999Z\"}",
      "timepicker:refreshIntervalDefaults": "{\"pause\":true,\"value\":0}"
    }
  }'

# ── CTFd (optional) ──
/opt/workshops/instruqt-ctfd.sh --enable --import dev-esql-basics --start lab1
